    models/
      loan.model.ts           # Loan, LoanType, LoanStatus, LoanApplication, DashboardStats, etc.
      user.model.ts           # User interface
    pipes/
      currency-format.pipe.ts # Custom currency formatter
    components/
      header/                 # Navigation, notifications panel, user menu
